<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center">

    <LinearLayout
        android:id="@+id/modal_overlay"
        android:layout_width="330dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/overlay_card_bg"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📡 騙局雷達 偵測結果"
            android:textColor="#F2873E"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/rate_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#F2873E"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/result_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="#ECECEE"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/keyword_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/overlay_box_bg"
            android:padding="12dp"
            android:textColor="#ECECEE"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/type_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/overlay_box_bg"
            android:padding="12dp"
            android:textColor="#ECECEE"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/remind_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/overlay_box_bg"
            android:padding="12dp"
            android:textColor="#C9D2E4"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/prevent_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/overlay_box_bg"
            android:padding="12dp"
            android:textColor="#C9D2E4"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/modal_close_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="關閉"
            android:textColor="#15171C"
            android:textStyle="bold"
            android:background="@drawable/overlay_btn_bg" />
    </LinearLayout>
    </ScrollView>
</FrameLayout>
