# 後端 API 位址 —— 複製這個檔成 .env 後填入你的後端位址
# (改完要重啟 expo:  npx expo start -c)
#
# Android 模擬器連電腦本機後端(最常用):
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000
#
# 實機(手機與電腦同網段,換成你電腦的區網 IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.0.10:3000
#
# 上線(HF Space,https 不需開 cleartext):
# EXPO_PUBLIC_API_BASE_URL=https://mintguess-fraud-radar.hf.space
